# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Mini App URL (your ngrok or public HTTPS URL)
WEBAPP_URL=https://your-domain.ngrok-free.app

# Internal API key (shared secret between API and Bot — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
INTERNAL_API_KEY=

# CORS allowed origins regex (leave empty for dev defaults: ngrok + localhost)
# For production, set to your domain: https://myapp\.example\.com
CORS_ORIGINS=

# PostgreSQL
POSTGRES_DB=planhabits
POSTGRES_USER=planhabits
POSTGRES_PASSWORD=planhabits_secret
